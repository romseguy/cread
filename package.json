{
  "name": "cread",
  "type": "module",
  "version": "0.1.0",
  "engines": {
    "node": ">=16.x"
  },
  "babelMacros": {
    "twin": {
      "preset": "emotion"
    }
  },
  "scripts": {
    "dev": "nodemon --watch server --watch server.ts --exec tsx server.ts",
    "build": "npm run clean && npm run build:client && npm run build:server",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "build:client": "vite build --outDir dist/app/client",
    "build:server": "tsc -p tsconfig.server.json && vite build --ssr src/entry-server.tsx --outDir dist/entry",
    "clean": "rimraf dist",
    "serve": "cross-env NODE_ENV=production node ./dist/app/server"
  },
  "dependencies": {
    "@babel/plugin-transform-react-jsx": "^7.24.7",
    "@emotion/babel-plugin-jsx-pragmatic": "^0.3.0",
    "@emotion/react": "^11.13.0",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "axios": "^1.6.5",
    "cartesian": "^1.0.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "date-fns": "^3.6.0",
    "dom-search-replace": "^1.3.0",
    "express": "^4.18.2",
    "extract-date": "^2.8.2",
    "glob": "^10.4.2",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.309.0",
    "moment-timezone": "^0.5.45",
    "mysql": "^2.18.1",
    "odt2html": "^1.0.1",
    "promise-mysql": "^5.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.1",
    "relative-date-names": "^1.0.4",
    "rimraf": "^5.0.5",
    "tailwind-merge": "^2.2.0",
    "tailwindcss-animate": "^1.0.7",
    "twin.macro": "^3.4.1",
    "vite": "^4.5.0"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mysql": "^2.15.26",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.7",
    "@types/react-router-dom": "^5.3.3",
    "@types/serve-static": "^1.15.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "babel-plugin-macros": "^3.1.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.39",
    "serve-static": "^1.15.0",
    "tailwindcss": "^3.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^3.14.0",
    "typescript": "4.9.5"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
