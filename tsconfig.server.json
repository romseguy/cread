{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsxdev",
    "incremental": true,
    "alwaysStrict": true,
    "checkJs": true,
    "declaration": true,
    "declarationMap": false,
    "outDir": "dist/app",
    "sourceMap": true,
    "types": ["vite/client"]
  },
  "include": ["api/**/*", "types/*", "server.ts"],
  "exclude": ["dist", "src//*.tsx"],
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "CommonJS"
    }
  }
}
