t=53\"width=\"560\" height=\"315\"frameborder=\"0\" allowfullscreen=\"true\"></iframe></div></div><br />and if i talk to my water without love... <img src=\"/forum/styles/cass/smilies/smiley.gif\"  class=\"smilie\" loading=\"lazy\" alt=\":-)\" title=\"Smile    :-)\" data-shortname=\":-)\" />","attachments":[],"reactions":[{"user_id":3863,"user":"findit","date":"2024-01-31T20:53:08+0100","reaction":"Like"},{"user_id":17281,"user":"Aylen","date":"2024-01-29T22:33:19+0100","reaction":"Like"},{"user_id":17361,"user":"seve","date":"2024-01-28T18:19:48+0100","reaction":"Like"},{"user_id":7597,"user":"hiker","date":"2024-01-28T06:39:14+0100","reaction":"Like"},{"user_id":16918,"user":"XPan","date":"2024-01-27T09:27:40+0100","reaction":"Like"},{"user_id":118,"user":"annp","date":"2024-01-27T02:06:30+0100","reaction":"Like"},{"user_id":5223,"user":"happyliza","date":"2024-01-25T00:28:02+0100","reaction":"Like"},{"user_id":17865,"user":"Anizta","date":"2024-01-24T04:16:58+0100","reaction":"Like"},{"user_id":4601,"user":"987baz","date":"2024-01-24T01:50:27+0100","reaction":"Like"},{"user_id":11429,"user":"trytofly","date":"2024-01-23T22:46:33+0100","reaction":"Like"},{"user_id":11403,"user":"Sylvia","date":"2024-01-23T19:58:14+0100","reaction":"Like"},{"user_id":12829,"user":"ryu","date":"2024-01-23T19:25:24+0100","reaction":"Like"},{"user_id":11897,"user":"PERLOU","date":"2024-01-23T18:42:03+0100","reaction":"Like"},{"user_id":7505,"user":"MK Scarlett","date":"2024-01-23T18:02:12+0100","reaction":"Like"},{"user_id":11382,"user":"Odin","date":"2024-01-23T17:07:40+0100","reaction":"Like"},{"user_id":5393,"user":"sbeaudry","date":"2024-01-23T16:15:25+0100","reaction":"Like"},{"user_id":18632,"user":"Bernardo GA","date":"2024-01-23T15:58:46+0100","reaction":"Like"},{"user_id":2556,"user":"clerck de bonk","date":"2024-01-23T15:21:44+0100","reaction":"Like"},{"user_id":7284,"user":"Don Cesar","date":"2024-01-23T14:51:59+0100","reaction":"Like"},{"user_id":15344,"user":"Cassis","dat